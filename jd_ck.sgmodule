#!name=京东pt_key/pt_pin上传TG
#!desc=自动抓取 api.m.jd.com 的 Cookie 并提取 pt_key/pt_pin 上传至指定 TG Bot
#!system=ios

[Script]
# pt_key/pt_pin上传脚本  
京东上传CK = type=http-request, pattern=^https?:\/\/api\.m\.jd\.com\/client\.action, requires-body=false, max-size=0, script-path=https://raw.githubusercontent.com/jdzjy/Surge/refs/heads/main/jd_ck.js

[MITM]
hostname = %APPEND% api.m.jd.com
